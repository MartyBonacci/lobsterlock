  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.8.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "discord.js": "^14.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
