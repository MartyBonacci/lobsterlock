{
  "name": "lobsterlock",
  "version": "0.1.0",
  "description": "Semantic security orchestrator for OpenClaw deployments",
  "type": "module",
  "bin": {
    "lobsterlock": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node --max-old-space-size=256 dist/index.js",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": ["openclaw", "security", "ai", "claude"],
